{
  "name": "rescript-sourcemap-test",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "res:build": "rescript",
    "res:watch": "rescript watch",
    "res:clean": "rescript clean",
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm run res:build && vite build",
    "node:source-map": "pnpm run res:build && node --enable-source-maps src/NodeProbe.js",
    "test:node-sourcemap": "node scripts/check-node-sourcemap.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@rescript/react": "^0.15.0",
    "@rescript/runtime": "13.0.0-alpha.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "rescript": "link:../rescript-sourcemap",
    "vite": "^7.2.0"
  }
}